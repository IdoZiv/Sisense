# Copy to `.env.local` (recommended) or `.env` for local development.
# Never commit real values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Sisense Embed SDK (iframe)
# Your Sisense origin (no trailing slash), e.g. https://your-instance.sisense.com
VITE_SISENSE_URL=
# Dashboard OID (the dashboard to load)
VITE_SISENSE_DASHBOARD_OID=
