{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
    }
  ],
  "hosting": {
    "public": "web/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/sessionLogin", "function": "sessionLogin" },
      { "source": "/api/sessionLogout", "function": "sessionLogout" },
      { "source": "/sso/sisense/login", "function": "sisenseLogin" },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}

